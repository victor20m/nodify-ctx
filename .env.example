# NodifyCtx example environment configuration

NODIFYCTX_CHAT_MODEL=your-chat-model-id
NODIFYCTX_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
NODIFYCTX_CHAT_BASE_URL=http://127.0.0.1:1234/v1
NODIFYCTX_EMBEDDINGS_BASE_URL=http://127.0.0.1:1234/v1
# Optional: use a single URL for both chat+embeddings
NODIFYCTX_MODEL_BASE_URL=
NODIFYCTX_MODEL_API_KEY=
NODIFYCTX_MODEL_TIMEOUT_SECONDS=10
NODIFYCTX_MAX_TOOL_ITERATIONS=10
# Set to a positive integer, or use 0 / unlimited / none for an effectively unlimited cap.
NODIFYCTX_GRAPH_RECURSION_LIMIT=100

NODIFYCTX_NEO4J_URI=bolt://127.0.0.1:7687
NODIFYCTX_NEO4J_USERNAME=neo4j
NODIFYCTX_NEO4J_PASSWORD=change-me

# Optional: override the per-repository scope ID used for Neo4j filtering and the default Qdrant collection name.
NODIFYCTX_COLLECTION_ID=
# Optional: override the full Qdrant collection name directly.
NODIFYCTX_QDRANT_COLLECTION=
NODIFYCTX_QDRANT_PATH=.nodifyctx/qdrant
# Prefer this when using the Docker Qdrant server.
NODIFYCTX_QDRANT_URL=http://127.0.0.1:6333
