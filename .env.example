# RepoContext example environment configuration

REPOCONTEXT_CHAT_MODEL=your-chat-model-id
REPOCONTEXT_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
REPOCONTEXT_CHAT_BASE_URL=http://127.0.0.1:1234/v1
REPOCONTEXT_EMBEDDINGS_BASE_URL=http://127.0.0.1:1234/v1
# Optional: use a single URL for both chat+embeddings
REPOCONTEXT_MODEL_BASE_URL=
REPOCONTEXT_MODEL_API_KEY=
REPOCONTEXT_MAX_TOOL_ITERATIONS=10
# Set to a positive integer, or use 0 / unlimited / none for an effectively unlimited cap.
REPOCONTEXT_GRAPH_RECURSION_LIMIT=100

REPOCONTEXT_NEO4J_URI=bolt://127.0.0.1:7687
REPOCONTEXT_NEO4J_USERNAME=neo4j
REPOCONTEXT_NEO4J_PASSWORD=change-me

# Optional: override the per-repository scope ID used for Neo4j filtering and the default Qdrant collection name.
REPOCONTEXT_COLLECTION_ID=
# Optional: override the full Qdrant collection name directly.
REPOCONTEXT_QDRANT_COLLECTION=
REPOCONTEXT_QDRANT_PATH=.repocontext/qdrant
# Prefer this when using the Docker Qdrant server.
REPOCONTEXT_QDRANT_URL=http://127.0.0.1:6333
